# ============================================================
# Tulasi AI — Environment Variables
# Copy to .env.local (frontend) and .env (backend)
# ============================================================

# ─── FRONTEND (.env.local in /frontend) ─────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_API_URL=http://localhost:8000    # or https://your-app.onrender.com in prod

# ─── BACKEND (.env in /backend) ─────────────────────────────
PROJECT_NAME=Tulasi AI
VERSION=1.0.0
API_V1_STR=/api/v1

# Supabase (for user auth + data)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Cloudflare R2 (for certificate storage)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY=your-r2-access-key-id
R2_SECRET_KEY=your-r2-secret-access-key
R2_BUCKET=tulasi-certificates
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# HuggingFace (for real RAG responses)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Optional: LangSmith tracing
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
