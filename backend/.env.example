# Backend .env Example
# Copy this file to .env and fill in real values
# NEVER commit .env to git

# ── Required ──────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
SECRET_KEY=your_super_secret_jwt_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# ── Database ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── AI Providers (Optional Fallbacks) ─────────────────────────────
GROQ_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-2-9b-it:free

# ── Supabase Auth (Required for Google OAuth) ─────────────────────
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_JWT_SECRET=

# ── Email / SMTP Notifications ────────────────────────────────────
# Example using Gmail App Password:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=your@gmail.com
#   SMTP_PASS=your_app_password   (generate at myaccount.google.com/apppasswords)
#   FROM_EMAIL=noreply@tulasiai.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@tulasiai.com
