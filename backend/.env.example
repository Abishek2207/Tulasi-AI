# Backend .env Example
# Copy this file to .env and fill in real values
# NEVER commit .env to git

# ── API Keys & Integrations ──────────────────────────────────────────
# AI Provider (Required)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional Fallbacks
GOOGLE_API_KEY=your_google_api_key_here_optional
GROQ_API_KEY=your_groq_api_key_here_optional

# Portfolio & Projects (Optional, Public API used by default)
GITHUB_TOKEN=your_github_token_here_optional

# Job / Internship Providers (Optional, RemoteOK used by default)
ADZUNA_APP_ID=your_adzuna_app_id_here_optional
ADZUNA_APP_KEY=your_adzuna_app_key_here_optional
JOOBLE_API_KEY=your_jooble_api_key_here_optional

# Hackathon / Events Data (Optional, Devpost RSS used by default)
UNSTOP_API_KEY=your_unstop_api_key_here_optional

# ── Database ──────────────────────────────────────────────────────
# SQLite (Local Testing Only): sqlite:///./tulasi_ai.db
# PostgreSQL (Production): postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Supabase Auth / Realtime (Optional/Required based on setup)
SUPABASE_URL=your_supabase_url_here_optional
SUPABASE_ANON_KEY=your_supabase_anon_key_here_optional
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here_optional

# ── Authentication & Security ──────────────────────────────────────
SECRET_KEY=your_super_secret_jwt_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# ── Email / SMTP Notifications (Optional) ──────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
FROM_EMAIL=noreply@tulasiai.com

# ── Professional Mode (Market Intel & Qdrant) ──────────────────────
# SerpApi / Custom Search for live job postings and skill demand
SERPAPI_API_KEY=your_serpapi_key_here_optional

# Qdrant Vector Database
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your_qdrant_api_key_here_optional
