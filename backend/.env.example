# Tulasi AI — Environment Variables Template
# Copy this file to .env and fill in your values.

# ─── Required ─────────────────────────────────────────────────────
# Google Gemini API key (used for AI chat + text-embedding-004)
GOOGLE_API_KEY="your-google-api-key-here"

# JWT secret for auth tokens — change this in production!
SECRET_KEY="change-me-in-production-super-secret"

# ─── Optional AI Providers ────────────────────────────────────────
# Groq API key (enables Llama 3.3 model for coding tasks)
GROQ_API_KEY=""

# Alias for GOOGLE_API_KEY (either one works)
GEMINI_API_KEY=""

# DeepSeek (if enabled)
DEEPSEEK_API_KEY=""

# ─── Langflow Integration ─────────────────────────────────────────
# Set this to your running Langflow endpoint to enable the Langflow pipeline.
# Leave empty to skip Langflow and go directly to Gemini.
# Example: http://localhost:7860/api/v1/run/YOUR_FLOW_ID
LANGFLOW_API_URL=""

# ─── Optional Services ────────────────────────────────────────────
YOUTUBE_API_KEY=""
SUPABASE_URL=""
SUPABASE_KEY=""
SUPABASE_JWT_SECRET=""
