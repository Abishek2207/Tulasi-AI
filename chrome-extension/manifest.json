{
    "manifest_version": 3,
    "name": "Tulasi AI",
    "version": "1.0",
    "description": "Your AI Study Assistant",
    "permissions": [
        "history",
        "storage",
        "activeTab"
    ],
    "action": {
        "default_popup": "popup.html"
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ]
        }
    ]
}